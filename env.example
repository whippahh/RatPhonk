# Discord OAuth2 (from discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# Discord Bot (separate bot token for broadcast listener)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_BROADCAST_CHANNEL_ID=   # channel TrackScape posts drops/kills to
DISCORD_CHAT_CHANNEL_ID=        # clan chat mirror channel

# WOM (no auth needed for reads, but group ID required)
WOM_GROUP_ID=                   # your clan's WOM group ID

# Session secret (generate a random 32+ char string)
SESSION_SECRET=change_this_to_a_random_secret_string_32chars

# Server
PORT=3000
FRONTEND_URL=http://localhost:5173